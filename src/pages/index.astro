---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
			}

			.controls-row {
				display: flex;
				flex-direction: row;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 2.5rem;
				width: 100%;
			}

			.filter-menu-container {
				position: relative;
				display: inline-flex;
				align-items: center;
				margin: 0;
			}

			.filter-trigger-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				background-color: transparent;
				color: #021300;
				border: 1px solid #e5e7eb;
				padding: 6px 18px;
				border-radius: 20px;
				font-family: "Poppins", system-ui, sans-serif;
				font-size: 14px;
				font-weight: 500;
				cursor: pointer;
				transition: all 0.2s ease;
				user-select: none;
				z-index: 95;
			}
			.filter-trigger-btn:hover,
			.filter-trigger-btn.active {
				border-color: #0aad0a;
				color: #0aad0a;
			}
			.filter-trigger-btn svg {
				width: 10px;
				height: 10px;
				transition: transform 0.2s ease;
			}
			.filter-trigger-btn.active svg {
				transform: rotate(90deg);
			}

			.filter-dropdown-strip {
				position: absolute;
				top: 50%;
				left: calc(100% + 0.6rem);
				background-color: #ffffff;
				border: 1px solid #e5e7eb;
				border-radius: 30px;
				/* Right padding removed — last-child margin handles trailing
				   gap so both ends of the scroll area are exactly equal */
				padding: 4px 0 4px 8px;
				display: flex;
				flex-direction: row;
				align-items: center;
				gap: 0.35rem;
				box-shadow: var(--box-shadow);
				z-index: 90;
				opacity: 0;
				pointer-events: none;
				transform: translate(-10px, -50%);
				transition:
					opacity 0.2s ease,
					transform 0.2s ease;

				width: min(360px, calc(100vw - 150px));
				overflow-x: auto;
				white-space: nowrap;
				scrollbar-width: none;
			}

			/* Hides scrollbar on Chrome, Safari, and Edge */
			.filter-dropdown-strip::-webkit-scrollbar {
				display: none;
			}

			/* Trailing gap: matches the 8px padding-left on the strip */
			.filter-dropdown-strip .filter-btn:last-child {
				margin-right: 8px;
			}

			/* FIX: Open state for the filter dropdown */
			.filter-dropdown-strip.open {
				opacity: 1;
				pointer-events: auto;
				transform: translate(0, -50%);
			}

			.filter-btn {
				background-color: #f2f2f2;
				color: #021300;
				border: 1px solid transparent;
				padding: 4px 14px;
				border-radius: 15px;
				font-family: "Poppins", system-ui, sans-serif;
				font-size: 13px;
				font-weight: 500;
				cursor: pointer;
				transition: all 0.2s ease;
				white-space: nowrap;
				display: inline-block;
				flex-shrink: 0;
			}
			.filter-btn:hover {
				color: #0aad0a;
			}
			.filter-btn.active {
				background-color: #021300;
				color: #ffffff;
			}

			.search-wrapper {
				position: relative;
				display: inline-flex;
				align-items: center;
				max-width: 280px;
				width: 100%;
				margin: 0;
			}
			.search-input {
				width: 100%;
				padding: 7px 16px 7px 36px;
				font-family: "Poppins", system-ui, sans-serif;
				font-size: 14px;
				font-weight: 500;
				color: #021300;
				background-color: transparent;
				border: 1px solid #e5e7eb;
				border-radius: 20px;
				outline: none;
				transition: all 0.2s ease;
			}
			.search-input::placeholder {
				color: #021300;
				opacity: 1;
				font-weight: 500;
			}
			.search-input:focus {
				border-color: #0aad0a;
				box-shadow: 0 0 0 3px rgba(10, 173, 10, 0.08);
			}
			.search-icon {
				position: absolute;
				left: 14px;
				color: #021300;
				width: 15px;
				height: 15px;
				pointer-events: none;
				transition: color 0.2s ease;
			}
			.search-input:focus + .search-icon {
				color: #0aad0a;
			}

			.no-results-frame {
				display: none;
				text-align: center;
				padding: 5rem 1rem;
				font-family: "Poppins", system-ui, sans-serif;
				color: rgb(var(--gray));
			}
			.no-results-frame h3 {
				color: #021300;
				margin-bottom: 0.5rem;
				font-size: 1.25rem;
			}
			.no-results-frame button {
				background-color: transparent;
				border: none;
				color: #0aad0a;
				font-family: "Poppins", system-ui, sans-serif;
				font-weight: 500;
				text-decoration: underline;
				cursor: pointer;
				padding: 0;
				font-size: 14px;
				margin-top: 0.5rem;
			}

			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
				transition: opacity 0.3s ease;
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}

			ul li.is-featured {
				width: 100% !important;
				margin-bottom: 1rem !important;
				text-align: center !important;
			}
			ul li.is-featured img {
				width: 100% !important;
				height: 360px !important;
				object-fit: cover !important;
			}
			ul li.is-featured .title {
				font-size: 2.369rem !important;
				text-wrap: balance;
			}

			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
				border: 2px solid #021300;
				width: 100%;
				height: 240px;
				object-fit: cover;
			}
			ul li a {
				display: flex;
				flex-direction: column;
				height: 100%;
			}
			.title {
				margin: 0 0 1rem 0;
				color: rgb(var(--black));
				line-height: 1.2;
				flex: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-family: "Poppins", system-ui, sans-serif;
				font-size: 14px;
			}

			ul li a:hover h4 {
				color: rgb(var(--gray));
			}

			ul a:hover img {
				box-shadow: var(--box-shadow);
			}

			.post-hidden {
				display: none !important;
			}

			.load-more-wrapper {
				display: flex;
				justify-content: center;
				margin-top: 4rem;
				width: 100%;
			}
			.btn-load-more {
				background-color: #021300;
				color: #ffffff;
				font-family: "Poppins", system-ui, sans-serif;
				font-size: 16px;
				font-weight: 500;
				padding: 12px 32px;
				border-radius: 6px;
				border: none;
				cursor: pointer;
				transition: background-color 0.2s ease;
			}
			.btn-load-more:hover {
				background-color: #0aad0a;
			}

			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li.is-featured .title {
					font-size: 1.563em !important;
				}
				.controls-row {
					position: relative;
					flex-direction: column;
					align-items: flex-start;
					gap: 1rem;
					margin-bottom: 2rem;
				}
				.search-wrapper {
					max-width: 100%;
				}
				/* Keep dropdown inline with the filter button row but
				   stretch its right edge to the right edge of the controls-row */
				.filter-menu-container {
					position: static;
				}
				.filter-dropdown-strip {
					position: absolute;
					top: 17px;
					left: calc(5.5rem + 0.6rem);
					right: 0;
					width: auto;
					transform: translate(10px, -50%);
					transition:
						opacity 0.2s ease,
						transform 0.2s ease;
				}
				.filter-dropdown-strip.open {
					transform: translate(0, -50%);
					opacity: 1;
					pointer-events: auto;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="controls-row">
					<div class="filter-menu-container" id="filter-menu-frame">
						<button
							id="filter-menu-trigger"
							class="filter-trigger-btn"
							aria-haspopup="true"
							aria-expanded="false"
						>
							Filter
							<svg
								xmlns="http://www.w3.org/2000/svg"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="3"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<polyline points="9 18 15 12 9 6"></polyline>
							</svg>
						</button>

						<div id="filter-dropdown" class="filter-dropdown-strip">
							<button class="filter-btn active" data-filter="all"
								>All</button
							>
							<button class="filter-btn" data-filter="Articles"
								>Articles</button
							>
							<button
								class="filter-btn"
								data-filter="Company News">Company News</button
							>
							<button
								class="filter-btn"
								data-filter="Guides for Bookers"
								>Guides for Bookers</button
							>
							<button
								class="filter-btn"
								data-filter="Guides for Venues"
								>Guides for Venues</button
							>
						</div>
					</div>

					<div class="search-wrapper">
						<input
							type="text"
							id="search-input"
							class="search-input"
							placeholder="Search articles..."
							aria-label="Search articles"
							autocomplete="off"
						/>
						<svg
							class="search-icon"
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="3"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<circle cx="11" cy="11" r="8"></circle>
							<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
						</svg>
					</div>
				</div>

				<div id="no-results" class="no-results-frame">
					<h3>No articles match your search</h3>
					<p>
						Try checking your spelling or selecting a different
						category.
					</p>
					<button id="clear-search-btn">Clear search & filters</button
					>
				</div>

				<ul id="blog-grid">
					{
						posts.map((post, index) => (
							<li
								class={
									index === 0
										? "blog-post-card is-featured"
										: "blog-post-card"
								}
								data-category={post.data.category || "Articles"}
							>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image
											width={720}
											height={360}
											src={post.data.heroImage}
											alt=""
										/>
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate
											date={post.data.pubDate}
										/>
										<span style="margin: 0 0.4rem; color: #e5e7eb;">
											|
										</span>
										<span>
											{post.data.category || "Articles"}
										</span>
									</p>
								</a>
							</li>
						))
					}
				</ul>

				<div class="load-more-wrapper" id="load-more-wrapper">
					<button id="load-more-btn" class="btn-load-more"
						>Load More</button
					>
				</div>
			</section>
		</main>
		<Footer />

		<script is:inline>
			let currentFilter = "all";
			let searchQuery = "";
			let visibleCount = 5;

			function updateGridEngine() {
				const posts = document.querySelectorAll(".blog-post-card");
				const loadMoreBtnWrapper =
					document.getElementById("load-more-wrapper");
				const noResultsBlock = document.getElementById("no-results");

				let matchingPosts = [];

				posts.forEach((post) => {
					const postCategory =
						post.getAttribute("data-category") || "Articles";
					const postTitle = (
						post.querySelector(".title")?.textContent || ""
					).toLowerCase();

					const passCategory =
						currentFilter === "all" ||
						postCategory === currentFilter;
					const passTextSearch = postTitle.includes(
						searchQuery.toLowerCase(),
					);

					if (passCategory && passTextSearch) {
						matchingPosts.push(post);
						post.classList.remove("post-hidden");
					} else {
						post.classList.add("post-hidden");
						post.classList.remove("is-featured");
					}
				});

				matchingPosts.forEach((post, index) => {
					if (index === 0) {
						post.classList.add("is-featured");
					} else {
						post.classList.remove("is-featured");
					}

					if (index >= visibleCount) {
						post.classList.add("post-hidden");
					}
				});

				if (noResultsBlock) {
					noResultsBlock.style.display =
						matchingPosts.length === 0 ? "block" : "none";
				}

				if (loadMoreBtnWrapper) {
					if (matchingPosts.length <= visibleCount) {
						loadMoreBtnWrapper.style.display = "none";
					} else {
						loadMoreBtnWrapper.style.display = "flex";
					}
				}
			}

			function initListingEngine() {
				const container = document.getElementById("filter-menu-frame");
				const trigger = document.getElementById("filter-menu-trigger");
				const dropdown = document.getElementById("filter-dropdown");
				const filterButtons = document.querySelectorAll(".filter-btn");
				const loadMoreBtn = document.getElementById("load-more-btn");
				const searchInput = document.getElementById("search-input");
				const clearSearchBtn =
					document.getElementById("clear-search-btn");

				if (!trigger || !dropdown || !container) return;

				const urlParams = new URLSearchParams(window.location.search);
				const filterParam = urlParams.get("filter");
				if (filterParam) {
					currentFilter = filterParam;
					filterButtons.forEach((b) => b.classList.remove("active"));
					const targetBtn = document.querySelector(
						`[data-filter="${filterParam}"]`,
					);
					if (targetBtn) targetBtn.classList.add("active");
				} else {
					currentFilter = "all";
				}

				trigger.onclick = function (e) {
					e.stopPropagation();
					const isOpen = dropdown.classList.toggle("open");
					trigger.classList.toggle("active", isOpen);
					trigger.setAttribute(
						"aria-expanded",
						isOpen ? "true" : "false",
					);
				};

				document.onclick = function (e) {
					if (!container.contains(e.target)) {
						dropdown.classList.remove("open");
						trigger.classList.remove("active");
						trigger.setAttribute("aria-expanded", "false");
					}
				};

				filterButtons.forEach((btn) => {
					btn.onclick = function (e) {
						e.stopPropagation();
						filterButtons.forEach((b) =>
							b.classList.remove("active"),
						);
						this.classList.add("active");

						currentFilter = this.getAttribute("data-filter");
						visibleCount = 5;

						window.history.replaceState(
							{},
							"",
							window.location.pathname,
						);

						updateGridEngine();
					};
				});

				if (searchInput) {
					searchInput.oninput = function () {
						searchQuery = this.value;
						visibleCount = 5;
						updateGridEngine();
					};
				}

				if (clearSearchBtn) {
					clearSearchBtn.onclick = function () {
						if (searchInput) searchInput.value = "";
						searchQuery = "";
						currentFilter = "all";

						window.history.replaceState(
							{},
							"",
							window.location.pathname,
						);

						filterButtons.forEach((b) =>
							b.classList.remove("active"),
						);
						const allFilterBtn = document.querySelector(
							'[data-filter="all"]',
						);
						if (allFilterBtn) allFilterBtn.classList.add("active");

						visibleCount = 5;
						updateGridEngine();
					};
				}

				if (loadMoreBtn) {
					loadMoreBtn.onclick = function () {
						visibleCount += 4;
						updateGridEngine();
					};
				}

				updateGridEngine();
			}

			initListingEngine();
			document.addEventListener("astro:page-load", initListingEngine);
		</script>
	</body>
</html>
