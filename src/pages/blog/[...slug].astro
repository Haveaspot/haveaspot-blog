---
// FIXED: Imported the "render" function from astro:content
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPost from "../../layouts/BlogPost.astro";

export async function getStaticPaths() {
	const posts = await getCollection("blog");
	return posts.map((post) => ({
		params: { slug: post.slug || post.id },
		props: post,
	}));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;

// FIXED: Changed from "post.render()" to "render(post)" to support Astro v6+
const { Content } = await render(post);

// Calculate Read Time
const words = post.body ? post.body.trim().split(/\s+/).length : 0;
const readTime = Math.max(1, Math.ceil(words / 200)) + " min read";
---

<BlogPost {...post.data} readTime={readTime}>
	<Content />
</BlogPost>
