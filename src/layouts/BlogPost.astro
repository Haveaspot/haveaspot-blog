---
import type { CollectionEntry } from "astro:content";
// FIXED: Imported Astro's native Image optimizer component
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";

type Props = CollectionEntry<"blog">["data"] & { readTime?: string };

const { title, description, pubDate, updatedDate, heroImage, readTime } =
	Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0 auto;
			}
			.hero-image {
				width: 100%;
			}
			/* FIXED: Updated styles to support the optimized Image component structure */
			.hero-image img,
			.hero-image picture img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				height: auto;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
				font-family: "Poppins", system-ui, sans-serif;
				font-weight: 500;
			}
			.last-updated-on {
				font-style: italic;
			}

			/* Back Button Layout */
			.back-btn-wrapper {
				width: 1020px;
				max-width: 100%;
				margin: 2rem auto 1.5rem auto;
			}
			.back-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				color: #021300;
				text-decoration: none;
				font-family: "Poppins", system-ui, sans-serif;
				font-weight: 500;
				font-size: 15px;
				transition:
					color 0.2s ease,
					transform 0.2s ease;
			}
			.back-btn:hover {
				color: #0aad0a;
			}
			.back-btn:hover svg {
				transform: translateX(-3px);
			}
			.back-btn svg {
				width: 20px;
				height: 20px;
				transition: transform 0.2s ease;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="back-btn-wrapper">
					<a href="/" class="back-btn">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<line x1="19" y1="12" x2="5" y2="12"></line>
							<polyline points="12 19 5 12 12 5"></polyline>
						</svg>
						Back to Blog
					</a>
				</div>

				<div class="hero-image">
					{
						heroImage && (
							/* FIXED: Swapped native <img> for Astro's optimized <Image /> component */
							<Image
								width={1020}
								height={510}
								src={heroImage}
								alt={title}
							/>
						)
					}
				</div>

				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />

							{
								readTime && (
									<>
										<span style="margin: 0 0.5rem; color: #e5e7eb;">
											|
										</span>
										<span>{readTime}</span>
									</>
								)
							}

							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on{" "}
										<FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
