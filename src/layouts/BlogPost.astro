---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";

type Props = CollectionEntry<"blog">["data"] & { readTime?: string };

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	readTime,
	category,
} = Astro.props;

// Related Posts Engine
const allPosts = await getCollection("blog");
const relatedPosts = allPosts
	.filter((post) => post.data.title !== title)
	.sort((a, b) => {
		const aCatMatch = a.data.category === category ? 1 : 0;
		const bCatMatch = b.data.category === category ? 1 : 0;

		if (aCatMatch !== bCatMatch) {
			return bCatMatch - aCatMatch;
		}

		return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
	})
	.slice(0, 2);
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0 auto;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img,
			.hero-image picture img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				height: auto;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
				font-family: "Poppins", system-ui, sans-serif;
				display: flex;
				align-items: center;
				justify-content: center;
				flex-wrap: wrap;
			}
			.separator {
				margin: 0 0.5rem;
				color: #e5e7eb;
			}
			.last-updated-on {
				font-style: italic;
				width: 100%;
				margin-top: 0.25rem;
			}

			.back-btn-wrapper {
				width: 1020px;
				max-width: 100%;
				margin: 2rem auto 1.5rem auto;
				display: flex;
				flex-direction: row;
				justify-content: space-between;
				align-items: center;
			}
			.back-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				background-color: transparent;
				color: #021300;
				border: 1px solid #e5e7eb;
				padding: 6px 18px;
				border-radius: 20px;
				font-family: "Poppins", system-ui, sans-serif;
				font-size: 14px;
				font-weight: 500;
				text-decoration: none;
				transition: all 0.2s ease;
				user-select: none;
			}
			.back-btn:hover {
				border-color: #0aad0a;
				color: #0aad0a;
			}
			.back-btn svg {
				width: 10px;
				height: 10px;
				transition: transform 0.2s ease;
			}

			.share-menu-container {
				position: relative;
				display: inline-flex;
				align-items: center;
			}

			.share-trigger-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				background-color: transparent;
				color: #021300;
				border: 1px solid #e5e7eb;
				padding: 6px 18px;
				border-radius: 20px;
				font-family: "Poppins", system-ui, sans-serif;
				font-size: 14px;
				font-weight: 500;
				cursor: pointer;
				transition: all 0.2s ease;
				user-select: none;
				z-index: 95;
			}
			.share-trigger-btn:hover,
			.share-trigger-btn.active {
				border-color: #0aad0a;
				color: #0aad0a;
			}
			.share-trigger-btn svg {
				width: 10px;
				height: 10px;
				transition: transform 0.2s ease;
			}
			.share-trigger-btn.active svg {
				transform: rotate(90deg);
			}

			.share-dropdown-strip {
				position: absolute;
				top: 50%;
				right: calc(100% + 0.6rem);
				background-color: #ffffff;
				border: 1px solid #e5e7eb;
				border-radius: 30px;
				padding: 6px 16px;
				display: flex;
				flex-direction: row;
				align-items: center;
				gap: 0.85rem;
				box-shadow: var(--box-shadow);
				z-index: 90;
				opacity: 0;
				pointer-events: none;
				transform: translate(10px, -50%);
				transition:
					opacity 0.2s ease,
					transform 0.2s ease;
			}
			.share-dropdown-strip.open {
				opacity: 1;
				pointer-events: auto;
				transform: translate(0, -50%);
			}
			.share-link {
				color: #021300;
				display: inline-flex;
				align-items: center;
				justify-content: center;
				transition:
					color 0.2s ease,
					transform 0.15s ease;
			}
			.share-link:hover {
				color: #0aad0a;
				transform: scale(1.08);
			}
			.share-link svg {
				width: 22px;
				height: 22px;
			}

			/* Related Posts Grid Styling */
			.related-posts-section {
				margin-top: 4rem;
				padding-top: 3rem;
				border-top: 1px solid #e5e7eb;
			}
			.related-header-row {
				display: flex;
				flex-direction: row;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 2rem;
			}
			.related-posts-title {
				font-family: "Poppins", system-ui, sans-serif;
				font-size: 1.5rem;
				font-weight: 600;
				color: #021300;
				margin: 0;
			}

			.view-related-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				background-color: transparent;
				color: #021300;
				border: 1px solid #e5e7eb;
				padding: 6px 18px;
				border-radius: 20px;
				font-family: "Poppins", system-ui, sans-serif;
				font-size: 14px;
				font-weight: 500;
				text-decoration: none;
				transition: all 0.2s ease;
			}
			.view-related-btn:hover {
				border-color: #0aad0a;
				color: #0aad0a;
			}
			.view-related-btn svg {
				width: 10px;
				height: 10px;
				transition: transform 0.2s ease;
			}

			.related-grid {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			.related-card {
				width: calc(50% - 1rem);
			}
			.related-card a {
				display: flex;
				flex-direction: column;
				height: 100%;
				text-decoration: none;
				transition: 0.2s ease;
			}
			.related-card img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
				width: 100%;
				height: 200px;
				object-fit: cover;
				transition: box-shadow 0.2s ease;
			}
			.related-card .related-title {
				margin: 0 0 0.4rem 0;
				color: rgb(var(--black));
				line-height: 1.2;
				font-size: 1.35rem;
				transition: color 0.2s ease;
				flex: 1;
			}
			.related-card a:hover .related-title {
				color: rgb(var(--gray));
			}
			.related-card a:hover img {
				box-shadow: var(--box-shadow);
			}
			.related-card .date {
				justify-content: flex-start !important;
				font-size: 14px;
				font-weight: 400;
			}

			@media (max-width: 720px) {
				/* Post title */
				.title h1 {
					font-size: 1.6rem;
				}

				/* Date / meta line */
				.date {
					font-size: 13px;
				}

				/* Body text and headings inside prose */
				.prose {
					font-size: 0.9375rem;
				}
				.prose h2 {
					font-size: 1.35rem;
				}
				.prose h3 {
					font-size: 1.15rem;
				}
				.prose h4 {
					font-size: 1rem;
				}

				.related-card {
					width: 100%;
				}
				.related-card img {
					height: auto;
					aspect-ratio: 16/9;
				}
				.related-header-row {
					flex-direction: column;
					align-items: flex-start;
					gap: 1rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="back-btn-wrapper">
					<a href="/" class="back-btn">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="3"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<polyline points="15 18 9 12 15 6"></polyline>
						</svg>
						Back to Blog
					</a>

					<div class="share-menu-container" id="share-menu-frame">
						<button
							id="share-menu-trigger"
							class="share-trigger-btn"
							aria-haspopup="true"
							aria-expanded="false"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="3"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<polyline points="15 18 9 12 15 6"></polyline>
							</svg>
							Share
						</button>

						<div id="share-dropdown" class="share-dropdown-strip">
							<a
								href="#"
								target="_blank"
								rel="noopener noreferrer"
								class="share-link"
								data-platform="linkedin"
								title="Share on LinkedIn"
								aria-label="Share on LinkedIn"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									viewBox="0 0 640 640"
									><path
										d="M512 96L127.9 96C110.3 96 96 110.5 96 128.3L96 511.7C96 529.5 110.3 544 127.9 544L512 544C529.6 544 544 529.5 544 511.7L544 128.3C544 110.5 529.6 96 512 96zM231.4 480L165 480L165 266.2L231.5 266.2L231.5 480L231.4 480zM198.2 160C219.5 160 236.7 177.2 236.7 198.5C236.7 219.8 219.5 237 198.2 237C176.9 237 159.7 219.8 159.7 198.5C159.7 177.2 176.9 160 198.2 160zM480.3 480L413.9 480L413.9 376C413.9 351.2 413.4 319.3 379.4 319.3C344.8 319.3 339.5 346.3 339.5 374.2L339.5 480L273.1 480L273.1 266.2L336.8 266.2L336.8 295.4L337.7 295.4C346.6 278.6 368.3 260.9 400.6 260.9C467.8 260.9 480.3 305.2 480.3 362.8L480.3 480z"
									></path></svg
								>
							</a>

							<a
								href="#"
								target="_blank"
								rel="noopener noreferrer"
								class="share-link"
								data-platform="facebook"
								title="Share on Facebook"
								aria-label="Share on Facebook"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									viewBox="0 0 640 640"
									><path
										d="M576 320C576 178.6 461.4 64 320 64C178.6 64 64 178.6 64 320C64 440 146.7 540.8 258.2 568.5L258.2 398.2L205.4 398.2L205.4 320L258.2 320L258.2 286.3C258.2 199.2 297.6 158.8 383.2 158.8C399.4 158.8 427.4 162 438.9 165.2L438.9 236C432.9 235.4 422.4 235 409.3 235C367.3 235 351.1 250.9 351.1 292.2L351.1 320L434.7 320L420.3 398.2L351 398.2L351 574.1C477.8 558.8 576 450.9 576 320z"
									></path></svg
								>
							</a>

							<a
								href="#"
								target="_blank"
								rel="noopener noreferrer"
								class="share-link"
								data-platform="whatsapp"
								title="Share on WhatsApp"
								aria-label="Share on WhatsApp"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									viewBox="0 0 640 640"
									><path
										d="M476.9 161.1C435 119.1 379.2 96 319.9 96C197.5 96 97.9 195.6 97.9 318C97.9 357.1 108.1 395.3 127.5 429L96 544L213.7 513.1C246.1 530.8 282.6 540.1 319.8 540.1L319.9 540.1C442.2 540.1 544 440.5 544 318.1C544 258.8 518.8 203.1 476.9 161.1zM319.9 502.7C286.7 502.7 254.2 493.8 225.9 477L219.2 473L149.4 491.3L168 423.2L163.6 416.2C145.1 386.8 135.4 352.9 135.4 318C135.4 216.3 218.2 133.5 320 133.5C369.3 133.5 415.6 152.7 450.4 187.6C485.2 222.5 506.6 268.8 506.5 318.1C506.5 419.9 421.6 502.7 319.9 502.7zM421.1 364.5C415.6 361.7 388.3 348.3 383.2 346.5C378.1 344.6 374.4 343.7 370.7 349.3C367 354.9 356.4 367.3 353.1 371.1C349.9 374.8 346.6 375.3 341.1 372.5C308.5 356.2 287.1 343.4 265.6 306.5C259.9 296.7 271.3 297.4 281.9 276.2C283.7 272.5 282.8 269.3 281.4 266.5C280 263.7 268.9 236.4 264.3 225.3C259.8 214.5 255.2 216 251.8 215.8C248.6 215.6 244.9 215.6 241.2 215.6C237.5 215.6 231.5 217 226.4 222.5C221.3 228.1 207 241.5 207 268.8C207 296.1 226.9 322.5 229.6 326.2C232.4 329.9 268.7 385.9 324.4 410C359.6 425.2 373.4 426.5 391 423.9C401.7 422.3 423.8 410.5 428.4 397.5C433 384.5 433 373.4 431.6 371.1C430.3 368.6 426.6 367.2 421.1 364.5z"
									></path></svg
								>
							</a>

							<a
								href="#"
								class="share-link"
								data-platform="email"
								title="Share via Email"
								aria-label="Share via Email"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									viewBox="0 0 640 640"
									><path
										d="M112 128C85.5 128 64 149.5 64 176C64 191.1 71.1 205.3 83.2 214.4L291.2 370.4C308.3 383.2 331.7 383.2 348.8 370.4L556.8 214.4C568.9 205.3 576 191.1 576 176C576 149.5 554.5 128 528 128L112 128zM64 260L64 448C64 483.3 92.7 512 128 512L512 512C547.3 512 576 483.3 576 448L576 260L377.6 408.8C343.5 434.4 296.5 434.4 262.4 408.8L64 260z"
									></path></svg
								>
							</a>
						</div>
					</div>
				</div>

				<div class="hero-image">
					{
						heroImage && (
							<Image
								width={1020}
								height={510}
								src={heroImage}
								alt={title}
							/>
						)
					}
				</div>

				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />

							{
								readTime && (
									<>
										<span class="separator">|</span>
										<span>{readTime}</span>
									</>
								)
							}

							<span class="separator">|</span>
							<span>{category || "Articles"}</span>

							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on{" "}
										<FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>

					<slot />

					{
						relatedPosts.length > 0 && (
							<div class="related-posts-section">
								<div class="related-header-row">
									<h3 class="related-posts-title">
										Related Articles
									</h3>
									<a
										href={`/?filter=${encodeURIComponent(category || "Articles")}`}
										class="view-related-btn"
									>
										More{" "}
										{(category || "articles").toLowerCase()}
										<svg
											xmlns="http://www.w3.org/2000/svg"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="3"
											stroke-linecap="round"
											stroke-linejoin="round"
										>
											<polyline points="9 18 15 12 9 6" />
										</svg>
									</a>
								</div>

								<ul class="related-grid">
									{relatedPosts.map((post) => (
										<li class="related-card">
											<a href={`/blog/${post.id}/`}>
												{post.data.heroImage && (
													<Image
														width={360}
														height={180}
														src={
															post.data.heroImage
														}
														alt=""
													/>
												)}
												<h4 class="related-title">
													{post.data.title}
												</h4>
												<p class="date">
													<FormattedDate
														date={post.data.pubDate}
													/>
													<span class="separator">
														|
													</span>
													<span>
														{post.data.category ||
															"Articles"}
													</span>
												</p>
											</a>
										</li>
									))}
								</ul>
							</div>
						)
					}
				</div>
			</article>
		</main>
		<Footer />

		<script>
			function initShareMenuEngine() {
				const container = document.getElementById("share-menu-frame");
				const trigger = document.getElementById("share-menu-trigger");
				const dropdown = document.getElementById("share-dropdown");

				if (!trigger || !dropdown || !container) return;

				trigger.onclick = function (e) {
					e.stopPropagation();
					const isOpen = dropdown.classList.toggle("open");
					trigger.classList.toggle("active", isOpen);
					trigger.setAttribute(
						"aria-expanded",
						isOpen ? "true" : "false",
					);
				};

				document.onclick = function (e) {
					if (!container.contains(e.target as Node)) {
						dropdown.classList.remove("open");
						trigger.classList.remove("active");
						trigger.setAttribute("aria-expanded", "false");
					}
				};

				const activeUrl = encodeURIComponent(window.location.href);
				const activeTitle = encodeURIComponent(
					document.title || "Check out this post!",
				);

				const linkedinLink = document.querySelector(
					'[data-platform="linkedin"]',
				);
				const facebookLink = document.querySelector(
					'[data-platform="facebook"]',
				);
				const whatsappLink = document.querySelector(
					'[data-platform="whatsapp"]',
				);
				const emailLink = document.querySelector(
					'[data-platform="email"]',
				);

				if (linkedinLink)
					linkedinLink.setAttribute(
						"href",
						`https://www.linkedin.com/sharing/share-offsite/?url=${activeUrl}`,
					);
				if (facebookLink)
					facebookLink.setAttribute(
						"href",
						`https://www.facebook.com/sharer/sharer.php?u=${activeUrl}`,
					);
				if (whatsappLink)
					whatsappLink.setAttribute(
						"href",
						`https://api.whatsapp.com/send?text=${activeTitle}%20${activeUrl}`,
					);
				if (emailLink)
					emailLink.setAttribute(
						"href",
						`mailto:?subject=${activeTitle}&body=${activeUrl}`,
					);
			}

			initShareMenuEngine();
			document.addEventListener("astro:page-load", initShareMenuEngine);
		</script>
	</body>
</html>
