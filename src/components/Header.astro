---
import logo from "../assets/logo.webp";

// ==========================================
// EASY EDIT VARIABLES
// Update your links and profile image here!
// ==========================================
const urls = {
	home: "https://haveaspot.com/",
	venues: "/venues",
	about: "/about",
	contact: "https://haveaspot.com/contact/",
	knowledgeBase: "https://support.haveaspot.com/",
};

const profileImage =
	"https://ui-avatars.com/api/?name=TV&background=0aad0a&color=fff&rounded=true&size=120";
const profileLink = "#";
---

<header class="has-header">
	<div class="has-header-inner">
		<a href="/" class="has-logo-link">
			<img src={logo.src} alt="Haveaspot Logo" class="has-logo-img" />
		</a>

		<div class="has-right-section">
			<button
				id="mobile-menu-btn"
				class="mobile-toggle"
				aria-label="Open Menu"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					width="24"
					height="24"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<line x1="3" y1="12" x2="21" y2="12"></line>
					<line x1="3" y1="6" x2="21" y2="6"></line>
					<line x1="3" y1="18" x2="21" y2="18"></line>
				</svg>
			</button>

			<nav id="mobile-nav" class="has-nav">
				<a href={urls.home}>Home</a>
				<a href={urls.venues}>Venues</a>
				<a href={urls.about}>About</a>
			</nav>

			<div class="has-divider"></div>

			<div class="has-icons">
				<a href={urls.contact} aria-label="Contact Us">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<rect width="20" height="16" x="2" y="4" rx="2"></rect>
						<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
						></path>
					</svg>
				</a>

				<a href={urls.knowledgeBase} aria-label="Knowledge Base">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"
						></path>
						<path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"
						></path>
					</svg>
				</a>

				<a href={profileLink} class="has-avatar" aria-label="Profile">
					<img src={profileImage} alt="User Avatar" />
				</a>
			</div>
		</div>
	</div>
</header>

<style is:global>
	/* Base Structure */
	.has-header {
		width: 100% !important;
		background-color: #ffffff !important;
		border-bottom: 1px solid #e5e7eb !important;
		font-family: "Poppins", system-ui, sans-serif !important;
		display: block !important;
		position: relative !important;
		z-index: 100 !important;
	}

	.has-header-inner {
		display: flex !important;
		flex-direction: row !important;
		align-items: center !important;
		justify-content: space-between !important;
		max-width: 1400px !important;
		margin: 0 auto !important;
		padding: 0 2rem !important;
		height: 72px !important;
		box-sizing: border-box !important;
	}

	.has-logo-link {
		display: flex !important;
		align-items: center !important;
		text-decoration: none !important;
		height: 100% !important;
		overflow: visible !important;
	}

	.has-logo-img {
		height: 35px !important;
		width: auto !important;
		max-width: none !important;
		display: block !important;
		object-fit: contain !important;
		margin: 0 !important;
		border-radius: 0 !important;
		box-shadow: none !important;
		background: transparent !important;
		overflow: visible !important;
		padding: 2px 0 !important;
	}

	.has-right-section {
		display: flex !important;
		flex-direction: row !important;
		align-items: center !important;
		height: 100% !important;
	}

	/* Mobile Toggle Hidden on Desktop */
	.mobile-toggle {
		display: none !important;
		background: transparent !important;
		border: none !important;
		color: #1f2937 !important;
		cursor: pointer !important;
		padding: 0.5rem !important;
		margin-right: 0.5rem !important;
	}

	.has-nav {
		display: flex !important;
		flex-direction: row !important;
		align-items: center !important;
		gap: 2rem !important;
		margin: 0 !important;
		padding: 0 !important;
	}

	.has-nav a {
		color: #1f2937 !important;
		text-decoration: none !important;
		font-size: 0.95rem !important;
		font-weight: 500 !important;
		display: block !important;
		transition: color 0.2s ease !important;
	}

	.has-nav a:hover {
		color: #0aad0a !important;
	}

	.has-divider {
		width: 1px !important;
		height: 24px !important;
		background-color: #e5e7eb !important;
		margin: 0 1.5rem !important;
		display: block !important;
	}

	.has-icons {
		display: flex !important;
		flex-direction: row !important;
		align-items: center !important;
		gap: 1.25rem !important;
	}

	.has-icons a {
		color: #1f2937 !important;
		display: flex !important;
		align-items: center !important;
		justify-content: center !important;
		text-decoration: none !important;
		transition:
			color 0.2s ease,
			transform 0.2s ease !important;
	}

	.has-icons a:hover {
		color: #0aad0a !important;
		transform: translateY(-1px) !important;
	}

	.has-icons svg {
		width: 20px !important;
		height: 20px !important;
		display: block !important;
	}

	.has-avatar {
		display: block !important;
		margin-left: 0.5rem !important;
	}

	.has-avatar img {
		width: 36px !important;
		height: 36px !important;
		border-radius: 50% !important;
		object-fit: cover !important;
		border: 2px solid transparent !important;
		margin: 0 !important;
		max-width: none !important;
		transition: border-color 0.2s ease !important;
	}

	.has-avatar:hover img {
		border-color: #0aad0a !important;
	}

	/* MOBILE LAYOUT OVERRIDES */
	@media (max-width: 768px) {
		.has-header-inner {
			padding: 0 1rem !important;
		}

		.has-divider {
			display: none !important;
		}

		.mobile-toggle {
			display: flex !important;
			align-items: center !important;
		}

		.has-icons {
			gap: 1rem !important;
		}

		/* Transforms the nav into a hidden dropdown */
		.has-nav {
			display: none !important; /* Hidden until toggled */
			position: absolute !important;
			top: 73px !important; /* Drops right below the border */
			left: 0 !important;
			width: 100% !important;
			background-color: #ffffff !important;
			flex-direction: column !important;
			align-items: flex-start !important;
			padding: 1.5rem 2rem !important;
			gap: 1.25rem !important;
			box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1) !important;
			border-bottom: 1px solid #e5e7eb !important;
			z-index: 99 !important;
		}

		.has-nav a {
			font-size: 1.1rem !important;
			width: 100% !important;
		}

		/* The class JavaScript will add when clicked */
		.has-nav.open {
			display: flex !important;
		}
	}
</style>

<script>
	// This tiny script listens for clicks on the hamburger button
	// and toggles the 'open' class on the navigation menu.
	function setupMobileMenu() {
		const btn = document.getElementById("mobile-menu-btn");
		const nav = document.getElementById("mobile-nav");

		if (btn && nav) {
			btn.onclick = () => {
				nav.classList.toggle("open");
			};
		}
	}

	// Runs immediately on page load
	setupMobileMenu();

	// Ensures it works with Astro's view transitions (if enabled)
	document.addEventListener("astro:page-load", setupMobileMenu);
</script>
