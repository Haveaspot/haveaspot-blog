---
import logo from "../assets/logo.webp";

const urls = {
	home: "https://haveaspot.com/",
	venues: "/venues",
	hosts: "/hosts",
	about: "https://about.haveaspot.com/",
	contact: "https://about.haveaspot.com/contact",
	knowledgeBase: "https://support.haveaspot.com/",
	login: "https://haveaspot.com/login",
	signup: "https://haveaspot.com/users/sign_up",
};
---

<header class="has-header">
	<div class="has-header-inner">
		<button
			id="mobile-menu-btn"
			class="mobile-toggle"
			aria-label="Open Menu"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<line x1="4" y1="12" x2="20" y2="12"></line>
				<line x1="4" y1="6" x2="20" y2="6"></line>
				<line x1="4" y1="18" x2="20" y2="18"></line>
			</svg>
		</button>

		<a href={urls.home} class="has-logo-link">
			<img src={logo.src} alt="Haveaspot Logo" class="has-logo-img" />
		</a>

		<a href={urls.login} class="mobile-login-link">Log In</a>

		<div id="mobile-overlay" class="mobile-overlay"></div>

		<nav id="mobile-nav" class="has-nav">
			<div class="mobile-drawer-header">
				<span class="mobile-drawer-title">Menu</span>
				<button
					id="mobile-close-btn"
					class="mobile-close"
					aria-label="Close Menu"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<line x1="18" y1="6" x2="6" y2="18"></line>
						<line x1="6" y1="6" x2="18" y2="18"></line>
					</svg>
				</button>
			</div>

			<div class="nav-links">
				<a href={urls.venues} class="nav-link">Venues</a>
				<a href={urls.hosts} class="nav-link">Hosts</a>
				<a href={urls.about} class="nav-link">About</a>
			</div>

			<div class="has-divider"></div>

			<div class="has-icons">
				<a
					href={urls.contact}
					class="icon-link"
					aria-label="Contact Us"
					title="Contact Us"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<rect width="20" height="16" x="2" y="4" rx="2"></rect>
						<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
						></path>
					</svg>
				</a>
				<a
					href={urls.knowledgeBase}
					class="icon-link"
					aria-label="Knowledge Base"
					title="Knowledge Base"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"
						></path>
						<path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"
						></path>
					</svg>
				</a>
			</div>

			<div class="auth-cluster">
				<a href={urls.login} class="btn-secondary">Log in</a>
				<a href={urls.signup} class="btn-primary">Sign up</a>
			</div>
		</nav>
	</div>
</header>

<style is:global>
	/* ==========================================
       BASE DESKTOP STRUCTURE
       ========================================== */
	.has-header {
		width: 100% !important;
		background-color: #ffffff !important;
		border-bottom: 1px solid #e5e7eb !important;
		font-family: "Poppins", system-ui, sans-serif !important;
		display: block !important;
		position: sticky !important;
		top: 0 !important;
		z-index: 100 !important;
	}

	.has-header-inner {
		display: flex !important;
		flex-direction: row !important;
		align-items: center !important;
		justify-content: space-between !important;
		max-width: 1536px !important;
		margin: 0 auto !important;
		padding: 0 1rem !important;
		height: 64px !important;
		box-sizing: border-box !important;
	}

	.has-logo-link {
		display: flex !important;
		align-items: center !important;
		text-decoration: none !important;
		height: 100% !important;
	}

	.has-logo-img {
		height: 34px !important;
		width: auto !important;
		display: block !important;
		object-fit: contain !important;
		margin: 0 !important;
		padding: 2px 0 !important;
		overflow: visible !important;
	}

	.has-nav {
		display: flex !important;
		flex-direction: row !important;
		align-items: center !important;
		margin: 0 !important;
		padding: 0 !important;
	}

	.nav-links {
		display: flex !important;
		flex-direction: row !important;
		gap: 0.5rem !important;
	}

	.nav-link {
		color: #021300 !important;
		text-decoration: none !important;
		font-size: 14px !important;
		font-weight: 500 !important;
		padding: 8px 12px !important;
		border-radius: 6px !important;
		transition:
			background-color 0.2s ease,
			color 0.2s ease !important;
	}

	.nav-link:hover {
		background-color: #f3f4f6 !important;
	}

	.has-divider {
		width: 1px !important;
		height: 24px !important;
		background-color: #e5e7eb !important;
		margin: 0 0.5rem !important;
		display: block !important;
	}

	.has-icons {
		display: flex !important;
		flex-direction: row !important;
		align-items: center !important;
		gap: 0.25rem !important;
		margin-right: 0.5rem !important;
	}

	.icon-link {
		color: #021300 !important;
		display: flex !important;
		align-items: center !important;
		justify-content: center !important;
		padding: 8px !important;
		border-radius: 6px !important;
		text-decoration: none !important;
		transition:
			background-color 0.2s ease,
			color 0.2s ease !important;
	}

	.icon-link:hover {
		background-color: #f3f4f6 !important;
		color: #0aad0a !important;
	}

	.auth-cluster {
		display: flex !important;
		flex-direction: row !important;
		align-items: center !important;
		gap: 0.5rem !important;
	}

	.btn-secondary,
	.btn-primary {
		font-size: 14px !important;
		font-weight: 500 !important;
		padding: 8px 16px !important;
		border-radius: 6px !important;
		text-decoration: none !important;
		transition: all 0.2s ease !important;
		line-height: 20px !important;
		height: 36px !important;
		box-sizing: border-box !important;
		display: flex !important;
		align-items: center !important;
		justify-content: center !important;
	}

	.btn-secondary {
		color: #021300 !important;
		background-color: transparent !important;
	}

	.btn-secondary:hover {
		background-color: #f3f4f6 !important;
	}

	.btn-primary {
		color: #ffffff !important;
		background-color: #0aad0a !important;
	}

	.btn-primary:hover {
		background-color: #0e491f !important;
	}

	.mobile-toggle,
	.mobile-login-link,
	.mobile-overlay,
	.mobile-drawer-header {
		display: none !important;
	}

	/* ==========================================
       MOBILE OVERRIDES
       ========================================== */
	@media (max-width: 1024px) {
		.mobile-toggle {
			display: flex !important;
			background: transparent !important;
			border: none !important;
			color: #021300 !important;
			cursor: pointer !important;
			padding: 0.5rem 0 !important;
		}

		.mobile-login-link {
			display: block !important;
			font-size: 14px !important;
			font-weight: 500 !important;
			color: #021300 !important;
			text-decoration: none !important;
			padding: 0.5rem 0 !important;
		}

		.has-logo-link {
			position: absolute !important;
			left: 50% !important;
			transform: translateX(-50%) !important;
		}

		.has-divider {
			display: none !important;
		}

		.mobile-overlay {
			display: block !important;
			position: fixed !important;
			top: 0 !important;
			left: 0 !important;
			right: 0 !important;
			bottom: 0 !important;
			background-color: rgba(0, 0, 0, 0.4) !important;
			z-index: 999 !important;
			opacity: 0 !important;
			pointer-events: none !important;
			transition: opacity 0.3s ease !important;
		}

		.mobile-overlay.open {
			opacity: 1 !important;
			pointer-events: auto !important;
		}

		/* Off-Canvas Mobile Drawer Settings */
		.has-nav {
			position: fixed !important;
			top: 0 !important;
			left: -100% !important;
			width: 85% !important;
			max-width: 340px !important;

			/* AMENDED: Upgraded from 100% to 100dvh to lock to current mobile dimensions */
			height: 100dvh !important;
			box-sizing: border-box !important;

			background-color: #ffffff !important;
			flex-direction: column !important;
			align-items: stretch !important;

			/* AMENDED: Increased bottom padding room to clear system home indicators */
			padding: 1.5rem 1.5rem 3rem 1.5rem !important;

			z-index: 1000 !important;
			overflow-y: auto !important;
			transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
			box-shadow: 2px 0 12px rgba(0, 0, 0, 0.1) !important;
		}

		.has-nav.open {
			left: 0 !important;
		}

		.mobile-drawer-header {
			display: flex !important;
			justify-content: space-between !important;
			align-items: center !important;
			margin-bottom: 2rem !important;
			border-bottom: 1px solid #e5e7eb !important;
			padding-bottom: 1rem !important;
		}

		.mobile-drawer-title {
			font-size: 18px !important;
			font-weight: 600 !important;
			color: #021300 !important;
		}

		.mobile-close {
			background: transparent !important;
			border: none !important;
			color: #6b7280 !important;
			cursor: pointer !important;
			padding: 0.25rem !important;
			transition: color 0.2s ease !important;
			display: flex !important;
		}

		.mobile-close:hover {
			color: #021300 !important;
		}

		.nav-links {
			flex-direction: column !important;
			width: 100% !important;
			gap: 0.5rem !important;
			margin-bottom: 1.5rem !important;
		}

		.nav-link {
			width: 100% !important;
			text-align: left !important;
			padding: 12px 0 !important;
			font-size: 16px !important;
			height: auto !important;
		}

		.nav-link:hover {
			background-color: transparent !important;
			color: #0aad0a !important;
		}

		.has-icons {
			flex-direction: row !important;
			justify-content: flex-start !important;
			width: 100% !important;
			gap: 1.5rem !important;
			padding: 1rem 0 !important;
			margin-right: 0 !important;
			border-top: 1px solid #e5e7eb !important;
		}

		/* Auth Cluster Panel */
		.auth-cluster {
			flex-direction: column !important;
			width: 100% !important;
			gap: 0.75rem !important;
			margin-top: auto !important;
			padding-top: 2rem !important;
			/* AMENDED: Ensures internal content behaves predictably within layout bounds */
			flex-shrink: 0 !important;
		}

		.btn-secondary,
		.btn-primary {
			width: 100% !important;
			padding: 12px 16px !important;
			height: auto !important;
			font-size: 15px !important;
		}

		.btn-secondary {
			border: 1px solid #e5e7eb !important;
		}
	}
</style>

<script is:inline>
	function toggleMobileMenu() {
		const nav = document.getElementById("mobile-nav");
		const overlay = document.getElementById("mobile-overlay");

		if (nav && overlay) {
			nav.classList.toggle("open");
			overlay.classList.toggle("open");

			if (nav.classList.contains("open")) {
				document.body.style.overflow = "hidden";
			} else {
				document.body.style.overflow = "";
			}
		}
	}

	function initHeader() {
		const btn = document.getElementById("mobile-menu-btn");
		const closeBtn = document.getElementById("mobile-close-btn");
		const overlay = document.getElementById("mobile-overlay");

		if (btn) btn.onclick = toggleMobileMenu;
		if (closeBtn) closeBtn.onclick = toggleMobileMenu;
		if (overlay) overlay.onclick = toggleMobileMenu;
	}

	initHeader();
	document.addEventListener("astro:page-load", initHeader);
</script>
